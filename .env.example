# PostgreSQL (메타 DB — audit_log/migration_history/schema_embeddings)
POSTGRES_USER=sqlpreshift
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sqlpreshift
DATABASE_URL=postgresql+psycopg://sqlpreshift:change-me@postgres:5432/sqlpreshift
# 대상 DB(샘플 시드용) — 컨테이너 네트워크에선 메타 DB와 동일 호스트(postgres) 사용
TARGET_DATABASE_URL=postgresql+psycopg://sqlpreshift:change-me@postgres:5432/sqlpreshift

# Ollama (호스트 직접 구동 — Mac Metal GPU. 컨테이너는 host.docker.internal 로 접속)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_EMBED_MODEL=bge-m3:latest
EMBEDDING_DIM=1024

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# 샘플 전용 분리 컨테이너 (메타 DB와 물리 분리 — 오염 방지)
SAMPLE_ERP_URL=postgresql+psycopg://demo:demo@pg_erp:5432/erp
SAMPLE_PAGILA_URL=postgresql+psycopg://postgres:postgres@pg_pagila:5432/pagila
