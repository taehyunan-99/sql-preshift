# docs 폴더는 추적하지 않음 (아이디어/내부 문서)
docs/

# Node / 프론트엔드
node_modules/
dist/
build/
.next/
# Next static export 산출물(설치형 빌드 입력) — 추적 안 함
out/
# electron-builder 패키징 산출물(.dmg/.app)
desktop/release/

# Python / 백엔드
__pycache__/
*.py[cod]
.venv/
venv/
# PyInstaller 빌드용 격리 venv (sidecar) — .spec은 추적(빌드 재현)
.venv-build/

# 환경 변수 / 시크릿
.env
.env.*
# 단, 비밀값 없는 예시 파일은 추적(clone 후 cp .env.example .env 안내가 동작하도록)
!.env.example

# 로컬 DB / 데이터
*.db
*.sqlite
*.sqlite3
data/

# 테스트/검증 산출물 (시나리오 결과·스크린샷 캡처)
backend/scenario_results.json
frontend/scripts/

# 로컬 LLM 모델 파일
*.gguf
models/
# 단, backend ORM 모델 디렉토리의 .py는 소스 코드다(LLM 모델 파일 아님) — 추적 대상.
!backend/app/models/
!backend/app/models/*.py

# OS / IDE
.DS_Store
.idea/
.vscode/

.awa/
.agent-harness/
.claude/
.agents/

# TypeScript 빌드 캐시
*.tsbuildinfo

# 설치형 SQLite 메타 DB (런타임 생성)
backend/data/
*.db
